{
  "framework": null,
  "trailingSlash": false,
  "buildCommand": "ng build --configuration=production",
  "outputDirectory": "dist/frontend/browser",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://api-iota-two-41.vercel.app/api/:match*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*\\.js|.*\\.css|.*\\.woff2?|.*\\.ttf|.*\\.eot|.*\\.svg|.*\\.png|.*\\.jpg|.*\\.webp|.*\\.avif|.*\\.ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    }
  ]
}
